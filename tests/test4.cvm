// Line comment test
let a = 10;
let b = 3;
let x = 1;
let y = 0;

/* Block comment test:
   next expressions should still run normally */

print a > b; //1(true)
print a >= 10;
print a != b;

print a << 1;
print a >> 1;

print a & b;
print a | b;
print a ^ b;
print ~a;

print x and y;
print x or y;
print not y;
print !x;

x++;
print x;
++x;
print x;
x--;
print x;
--x;
print x;

a += 5;
print a;
a -= 2;
print a;
a *= 2;
print a;
a /= 3;
print a;
a %= 4;
print a;

a = 6;
a &= 3;
print a;
a |= 8;
print a;
a ^= 2;
print a;
a <<= 1;
print a;
a >>= 2;
print a;
