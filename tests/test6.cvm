let x = 0;
let y = 0;

// short-circuit: RHS should not execute
if ((x != 0) and ((y = 1) == 1)) {
    print 999;
}
print y;

if ((x == 0) or ((y = 2) == 2)) {
    print 1;
}
print y;

let a = 5;
print a++;
print a;
print ++a;
print a;

let i = 0;
let s = 0;
while (i < 6) {
    i++;
    if (i == 2) {
        continue;
    }
    if (i == 5) {
        break;
    }
    s += i;
}
print s;
